{
  "name": "@ff-restaurent/api",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/server.js",
    "start": "node dist/server.js",
    "pretypecheck": "prisma generate --schema prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts",
    "lint": "eslint src --ext ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:indexes:verify": "tsx prisma/verify-final-query-indexes.ts",
    "prisma:phones:backfill": "tsx prisma/backfill-user-phones.ts",
    "prisma:phase2:contract:verify": "tsx prisma/verify-phase2-contract.ts",
    "prisma:root:bootstrap": "tsx prisma/bootstrap-root-admin.ts",
    "prisma:root:recover": "tsx prisma/recover-root-admin.ts",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@ff-restaurent/shared": "1.1.0",
    "@prisma/client": "^6.11.1",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^6.11.1",
    "tsx": "^4.20.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
