generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChefRole {
  SOUS_CHEF
  HEAD_CHEF
}

enum SystemRole {
  ROOT_ADMIN
}

enum PasswordResetStatus {
  PENDING
  CODE_ISSUED
  USED
  REJECTED
  SUPERSEDED
  LOCKED
  EXPIRED
}

enum EntryStatus {
  ACTIVE
  ARCHIVED
}

enum PaymentStatus {
  PAID
  WAITING
}

enum RestaurantPlatform {
  GRAB
  SHOPEE_FOOD
  BE_FOOD
  GOJEK
  WEBSITE
  FACEBOOK
  OTHER
}

model User {
  id                  String                   @id @default(cuid())
  username            String                   @unique
  phone               String?                  @unique
  name                String
  passwordHash        String
  chefRole            ChefRole?
  systemRole          SystemRole?              @unique
  sessionVersion      Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  billsCreated        Bill[]                   @relation("BillCreator")
  restaurants         RestaurantEntry[]        @relation("RestaurantCreator")
  participants        BillParticipant[]
  notifications       Notification[]
  roleChangesMade     RoleAuditLog[]           @relation("RoleChangedBy")
  roleChangesReceived RoleAuditLog[]           @relation("RoleChangedUser")
  billAuditLogs       BillAuditLog[]
  favorites           UserFavorite[]
  rootTransfersFrom   RootAdminTransferAudit[] @relation("RootTransferredFrom")
  rootTransfersTo     RootAdminTransferAudit[] @relation("RootTransferredTo")
  passwordResetRequests PasswordResetRequest[]
}

model PasswordResetRequest {
  id             String              @id @default(cuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeKey      String?             @unique
  status         PasswordResetStatus @default(PENDING)
  codeHash       String?
  expiresAt      DateTime?
  failedAttempts Int                 @default(0)
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model RootAdminTransferAudit {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("RootTransferredFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("RootTransferredTo", fields: [toUserId], references: [id])
  createdAt  DateTime @default(now())
}

model RestaurantEntry {
  id            String         @id @default(cuid())
  name          String
  address       String
  addressLine   String?
  provinceCode  String?
  provinceName  String?
  wardCode      String?
  wardName      String?
  phone          String?
  bannerImageUrl String?
  cuisineType   String
  type          String
  avatarUrl     String?
  links         Json           @default("[]")
  isRecommended Boolean        @default(false)
  isFavorite    Boolean        @default(false)
  status        EntryStatus    @default(ACTIVE)
  createdById   String
  createdBy     User           @relation("RestaurantCreator", fields: [createdById], references: [id])
  bills         Bill[]
  favorites     UserFavorite[]
  platformLinks RestaurantPlatformLink[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RestaurantPlatformLink {
  id           String             @id @default(cuid())
  restaurantId String
  restaurant   RestaurantEntry    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  platform     RestaurantPlatform
  label        String?
  url          String
  sortOrder    Int

  @@unique([restaurantId, url])
  @@unique([restaurantId, sortOrder])
  @@index([restaurantId, platform])
}

model Bill {
  id           String            @id @default(cuid())
  restaurantId String
  restaurant   RestaurantEntry   @relation(fields: [restaurantId], references: [id])
  baseCost     Int
  vat          Int
  shippingFee  Int
  discounts    Json              @default("[]")
  vouchers     Json              @default("[]")
  totalCost    Int
  qrCodePath   String?
  paymentUrl   String?
  status       EntryStatus       @default(ACTIVE)
  createdById  String
  createdBy    User              @relation("BillCreator", fields: [createdById], references: [id])
  participants BillParticipant[]
  auditLogs    BillAuditLog[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model BillParticipant {
  billId            String
  memberId          String
  originCost        Int
  allocatedVat      Int
  allocatedShipping Int
  discountApplied   Int
  finalPrice        Int
  paymentStatus     PaymentStatus @default(WAITING)
  paidAt            DateTime?
  bill              Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)
  member            User          @relation(fields: [memberId], references: [id])

  @@id([billId, memberId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  billId    String?
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model RoleAuditLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("RoleChangedUser", fields: [userId], references: [id])
  changedById String
  changedBy   User      @relation("RoleChangedBy", fields: [changedById], references: [id])
  fromRole    ChefRole?
  toRole      ChefRole?
  createdAt   DateTime  @default(now())
}

model BillAuditLog {
  id        String   @id @default(cuid())
  billId    String
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
}

model UserFavorite {
  userId       String
  restaurantId String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   RestaurantEntry @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@id([userId, restaurantId])
}
